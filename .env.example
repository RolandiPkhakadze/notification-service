# App
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*         # Comma-separated origins, e.g. https://app.example.com

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=notification_service
DB_SSL=false                       # Set to true for AWS RDS
DB_SSL_REJECT_UNAUTHORIZED=true    # Set to false only if using self-signed certs

# SendGrid
SENDGRID_API_KEY=SG.your_api_key_here
SENDGRID_FROM_EMAIL=your_verified_sender@example.com
SENDGRID_WEBHOOK_SECRET=your_webhook_signing_secret

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15005550006

# Firebase FCM
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
